#!/usr/bin/env python3
"""bwweekly — append last 7 days of total bandwidth to /var/lib/bwmon/weekly_totals.log"""
import os, sys, time
from datetime import datetime
from zoneinfo import ZoneInfo

TZ = ZoneInfo('America/New_York')

IFACE   = sys.argv[1] if len(sys.argv) > 1 else 'enp3s0'
DIR     = '/var/lib/bwmon'
DATA    = f'{DIR}/bw_{IFACE}.csv'
LOG     = f'{DIR}/weekly_totals.log'
WINDOW  = 7 * 86400

def fmt_bytes(b):
    if b >= 1024 ** 4: return f"{b / 1024**4:.2f} TB"
    if b >= 1024 ** 3: return f"{b / 1024**3:.2f} GB"
    return f"{b / 1024**2:.2f} MB"   # always MB minimum

now     = time.time()
cutoff  = now - WINDOW
rows    = []

try:
    with open(DATA) as f:
        for line in f:
            p = line.strip().split(',')
            if len(p) == 3:
                try:
                    rows.append((int(p[0]), float(p[1]), float(p[2])))
                except ValueError:
                    pass
except FileNotFoundError:
    sys.exit(f"bwweekly: no data file at {DATA}")

# Keep only the window; sort by time
rows = sorted(r for r in rows if r[0] >= cutoff)

if not rows:
    sys.exit("bwweekly: no samples in the last 7 days — nothing written")

# Integrate: bytes = rate_bps / 8 * actual_elapsed_seconds between consecutive samples.
# For the first sample use 300s (one cron tick) as the interval estimate.
total_rx = total_tx = 0.0
prev_ts = rows[0][0] - 300

for ts, rx_bps, tx_bps in rows:
    dt = ts - prev_ts
    if 0 < dt <= 3600:          # ignore gaps > 1 hour (reboots, missed crons)
        total_rx += rx_bps / 8 * dt
        total_tx += tx_bps / 8 * dt
    prev_ts = ts

week_start = datetime.fromtimestamp(rows[0][0], TZ).strftime('%Y-%m-%d %H:%M %Z')
week_end   = datetime.fromtimestamp(rows[-1][0], TZ).strftime('%Y-%m-%d %H:%M %Z')
logged_at  = datetime.now(TZ).strftime('%Y-%m-%d %H:%M %Z')

line = (
    f"{logged_at}  |  {week_start} → {week_end}  |  "
    f"RX {fmt_bytes(total_rx):>12}  "
    f"TX {fmt_bytes(total_tx):>12}  "
    f"total {fmt_bytes(total_rx + total_tx):>12}  "
    f"| {len(rows)} samples  iface={IFACE}\n"
)

os.makedirs(DIR, exist_ok=True)
with open(LOG, 'a') as f:
    f.write(line)

print(line, end='')
