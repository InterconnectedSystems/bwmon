#!/usr/bin/env python3
"""bwhistory — 4-panel bandwidth histograph (24h / 1w / 1m / 6m)."""
import sys, os, time
from datetime import datetime
from collections import defaultdict
from zoneinfo import ZoneInfo

TZ = ZoneInfo('America/New_York')

IFACE = sys.argv[1] if len(sys.argv) > 1 else 'enp3s0'
DIR   = '/var/lib/bwmon'
DATA  = f'{DIR}/bw_{IFACE}.csv'
H     = 8    # chart rows per half (RX above axis, TX below)
LW    = 10   # y-axis column width (includes the ┤ or │ glyph)

C = {
    'reset': '\033[0m', 'bold': '\033[1m',
    'rx':    '\033[38;5;81m',    # cyan-blue
    'tx':    '\033[38;5;214m',   # amber
    'head':  '\033[38;5;153m',   # light blue
    'axis':  '\033[38;5;240m',   # dark grey
    'label': '\033[38;5;245m',   # medium grey
    'muted': '\033[38;5;238m',   # very dark grey
    'hi':    '\033[38;5;255m',   # white
}
FRAC = ' ▁▂▃▄▅▆▇█'

def cc(k, t):
    return f"{C[k]}{t}{C['reset']}"

def fmt_bps(bps):
    if bps == 0:   return '0 bps'
    if bps >= 1e9: return f"{bps/1e9:.2f} Gbps"
    if bps >= 1e6: return f"{bps/1e6:.2f} Mbps"
    if bps >= 1e3: return f"{bps/1e3:.1f} Kbps"
    return f"{bps:.0f} bps"

def fmt_short(bps):
    if bps == 0:   return '0'
    if bps >= 1e9: return f"{bps/1e9:.1f}G"
    if bps >= 1e6: return f"{bps/1e6:.1f}M"
    if bps >= 1e3: return f"{bps/1e3:.0f}K"
    return str(int(bps))

def load_data():
    rows = []
    try:
        with open(DATA) as f:
            for line in f:
                p = line.strip().split(',')
                if len(p) == 3:
                    try:
                        rows.append((int(p[0]), float(p[1]), float(p[2])))
                    except ValueError:
                        pass
    except FileNotFoundError:
        pass
    return sorted(rows)

def bucket_data(rows, start, end, n):
    if n <= 0 or end <= start:
        return []
    bsz = (end - start) / n
    rx_acc, tx_acc = defaultdict(list), defaultdict(list)
    for ts, rx, tx in rows:
        if start <= ts < end:
            b = min(int((ts - start) / bsz), n - 1)
            rx_acc[b].append(rx)
            tx_acc[b].append(tx)
    return [
        (start + b * bsz,
         sum(rx_acc[b]) / len(rx_acc[b]) if rx_acc[b] else 0,
         sum(tx_acc[b]) / len(tx_acc[b]) if tx_acc[b] else 0)
        for b in range(n)
    ]

def rx_char(row, val, mx):
    """Bar char for RX (bars rise from bottom, row 0 = top of section)."""
    if mx <= 0 or val <= 0:
        return ' '
    bh  = min(val / mx, 1.0) * H
    full, frac = int(bh), bh - int(bh)
    dist = H - 1 - row   # distance from bottom
    if dist < full:
        return '█'
    if dist == full and frac > 0:
        return FRAC[min(round(frac * 8), 8)]
    return ' '

def tx_char(row, val, mx):
    """Bar char for TX (bars fall from top, row 0 = top of section = nearest axis)."""
    if mx <= 0 or val <= 0:
        return ' '
    bh  = min(val / mx, 1.0) * H
    full, frac = int(bh), bh - int(bh)
    if row < full:
        return '█'
    if row == full and frac > 0:
        return FRAC[min(round(frac * 8), 8)]
    return ' '

def y_prefix(label_str, is_tick):
    glyph = '┤' if is_tick else '│'
    return cc('axis', label_str.rjust(LW - 1) + glyph)

def bar_row(row_chars, color_key):
    parts = []
    for ch in row_chars:
        if ch != ' ':
            parts.append(C[color_key] + ch + C['reset'])
        else:
            parts.append(' ')
    return ''.join(parts)

def x_labels(buckets, bw, tfmt):
    n = len(buckets)
    total = n * bw
    chars  = [' '] * total
    sample = datetime.now(TZ).strftime(tfmt)
    llen   = len(sample)
    # minimum bucket-gap so labels don't collide
    step = max(1, (llen + 1 + bw - 1) // bw)
    step = max(step, n // 16)   # also keep count sane
    for i in range(0, n, step):
        lbl = datetime.fromtimestamp(buckets[i][0], TZ).strftime(tfmt)
        pos = i * bw
        for j, ch in enumerate(lbl):
            if pos + j < total:
                chars[pos + j] = ch
    return ' ' * LW + C['label'] + ''.join(chars) + C['reset']

def render_section(title, buckets, bw, tfmt):
    n = len(buckets)
    if n == 0:
        return [f"  {cc('muted', title + ': no data')}"]

    rx_vals = [b[1] for b in buckets]
    tx_vals = [b[2] for b in buckets]
    rx_peak = max(rx_vals) if rx_vals else 0
    tx_peak = max(tx_vals) if tx_vals else 0
    rx_avg  = sum(rx_vals) / n
    tx_avg  = sum(tx_vals) / n
    mx      = max(rx_peak, tx_peak, 1)
    bar_w   = n * bw

    out = []

    # ── Section header ──────────────────────────────────────────────────
    out.append(cc('axis', '─' * (LW + bar_w + 2)))
    out.append(
        f"  {C['bold']}{C['head']}{title}{C['reset']}  "
        f"{cc('rx', '▼ RX')}  peak {cc('hi', fmt_bps(rx_peak))}  avg {cc('rx', fmt_bps(rx_avg))}    "
        f"{cc('tx', '▲ TX')}  peak {cc('hi', fmt_bps(tx_peak))}  avg {cc('tx', fmt_bps(tx_avg))}"
    )
    out.append('')

    # ── RX half ─────────────────────────────────────────────────────────
    for row in range(H):
        if row == 0:
            pre = y_prefix(fmt_short(mx), True)
        elif row == H // 2:
            pre = y_prefix(fmt_short(mx / 2), True)
        else:
            pre = y_prefix('', False)
        chars = [rx_char(row, b[1], mx) * bw for b in buckets]
        out.append(pre + bar_row(chars, 'rx'))

    # ── Centre axis ─────────────────────────────────────────────────────
    out.append(cc('axis', ' ' * (LW - 1) + '┼' + '─' * bar_w))

    # ── TX half ─────────────────────────────────────────────────────────
    for row in range(H):
        if row == H // 2:
            pre = y_prefix(fmt_short(mx / 2), True)
        elif row == H - 1:
            pre = y_prefix(fmt_short(mx), True)
        else:
            pre = y_prefix('', False)
        chars = [tx_char(row, b[2], mx) * bw for b in buckets]
        out.append(pre + bar_row(chars, 'tx'))

    # ── Bottom axis + x-labels ───────────────────────────────────────────
    out.append(cc('axis', ' ' * (LW - 1) + '└' + '─' * bar_w))
    out.append(x_labels(buckets, bw, tfmt))
    out.append('')

    return out

def main():
    try:
        term_w = os.get_terminal_size().columns
    except OSError:
        term_w = 120

    now  = time.time()
    rows = load_data()
    avail = term_w - LW - 2   # chars available for bars

    # (label, lookback_seconds, max_buckets, time_format)
    # max_buckets: one bucket per 5-min sample at finest, coarser for longer ranges
    RANGES = [
        ('24 Hours', 86_400,      min(288,  avail), '%H:%M'),
        ('1 Week',   604_800,     min(168,  avail), '%a %d'),
        ('1 Month',  2_592_000,   min(120,  avail), '%m/%d'),
        ('6 Months', 15_552_000,  min(180,  avail), '%b %d'),
    ]

    # Main header
    print()
    print(
        f"  {C['bold']}{C['head']}BANDWIDTH HISTORY{C['reset']}  "
        f"{cc('axis', IFACE)}  "
        f"{C['label']}{datetime.now(TZ).strftime('%Y-%m-%d %H:%M %Z')}{C['reset']}  "
        f"{C['muted']}{len(rows)} samples  5-min resolution{C['reset']}"
    )

    if not rows:
        print(f"\n  {cc('muted', 'No data yet — bwcollect must run at least once.')}")
        print(f"  {cc('muted', 'Add to crontab:  */5 * * * *  /usr/local/bin/bwcollect')}")
        print()
        return

    oldest = datetime.fromtimestamp(rows[0][0], TZ).strftime('%Y-%m-%d %H:%M %Z')
    newest = datetime.fromtimestamp(rows[-1][0], TZ).strftime('%Y-%m-%d %H:%M %Z')
    print(f"  {C['muted']}data range: {oldest} → {newest}{C['reset']}")

    for label, lookback, max_b, tfmt in RANGES:
        start   = now - lookback
        n       = max(1, min(max_b, avail))
        bw      = max(1, avail // n)
        buckets = bucket_data(rows, start, now, n)
        # data coverage indicator
        filled  = sum(1 for b in buckets if b[1] > 0 or b[2] > 0)
        pct     = int(filled / n * 100) if n else 0
        for line in render_section(
            f"{label}  {C['muted']}({pct}% coverage){C['reset']}", buckets, bw, tfmt
        ):
            print(line)

main()
